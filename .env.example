# ============================================
# CONFIGURACIÓN BASE DE DATOS MYSQL (RAILWAY)
# ============================================
DB_HOST=${MySQL.MYSQLHOST}
DB_DATABASE=${MySQL.MYSQLDATABASE}
DB_USERNAME=${MySQL.MYSQLUSER}
DB_PASSWORD=${MySQL.MYSQLPASSWORD}
DB_PORT=${MySQL.MYSQLPORT}
DB_SSL=true

# ============================================
# CONFIGURACIÓN SERVIDOR
# ============================================
NODE_ENV=production
PORT=8080

# ============================================
# SEGURIDAD - JWT SECRET
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ============================================
KEY_TOKEN=your_jwt_secret_here_generate_with_crypto

# ============================================
# VARIABLES OPCIONALES (Microservicios externos)
# ============================================
LOCAL_URL=http://localhost:8080
AZURE_AREAS_URL=optional_your_data
AZURE_PRODUCTS_URL=optional_your_data
AZURE_USER_URL=optional_your_data